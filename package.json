{
  "name": "tqs",
  "version": "1.0.0",
  "description": "quick scripts for typescript",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "tqs": "./dist/cli/index.js"
  },
  "scripts": {
    "release": "release-it",
    "build": "npm run build:ts",
    "clean:generated": "bash scripts/clean-generated.sh",
    "setup": "bash scripts/setup.sh",
    "stage:quickjs": "bash scripts/stage-quickjs.sh",
    "build:quickjs": "npm run stage:quickjs && bash scripts/build-quickjs.sh",
    "build:ts": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/cli.js",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "smoke:pack": "bash scripts/smoke-packed-artifact.sh",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepare": "npm run build:ts",
    "prepack": "npm run stage:quickjs && npm run build:ts",
    "postpack": "bash scripts/clean-generated.sh . quickjs"
  },
  "keywords": ["typescript", "cli", "scripts", "tools", "quickjs", "maybefetch"],
  "author": "Jeffry Wainwright",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffrywainwright/tqs.git"
  },
  "bugs": {
    "url": "https://github.com/jeffrywainwright/tqs/issues"
  },
  "homepage": "https://github.com/jeffrywainwright/tqs#readme",
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/node": "^24.0.0",
    "node-addon-api": "^8.0.0",
    "node-gyp": "^10.0.0",
    "oxlint": "^0.9.0",
    "release-it": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {},
  "peerDependencies": {},
  "files": [
    "dist/",
    "src/types.ts",
    "native/include/",
    "native/src/",
    "deps/quickjs-ng/"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./quickjs": "./dist/quickjs.js",
    "./types": "./src/types.ts"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.0.0"
  },
  "release-it": {
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md"
      }
    },
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}",
      "requireBranch": "main",
      "requireCleanWorkingDir": true
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": true
    }
  }
}

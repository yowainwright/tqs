{
  "name": "tqs",
  "version": "1.0.0",
  "description": "quick scripts for typescript",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "tqs": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:quickjs && npm run build:ts",
    "build:quickjs": "bash scripts/build-quickjs.sh",
    "build:ts": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/cli.js",
    "lint": "oxlint src",
    "format": "oxfmt src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepare": "npm run build"
  },
  "keywords": ["typescript", "cli", "scripts", "tools", "quickjs", "maybefetch"],
  "author": "Jeffry Wainwright",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffrywainwright/tqs.git"
  },
  "bugs": {
    "url": "https://github.com/jeffrywainwright/tqs/issues"
  },
  "homepage": "https://github.com/jeffrywainwright/tqs#readme",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "node-addon-api": "^8.0.0",
    "node-gyp": "^10.0.0",
    "oxlint": "^0.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {},
  "peerDependencies": {},
  "files": [
    "dist/",
    "bin/",
    "src/types.ts"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./quickjs": "./dist/quickjs.js",
    "./types": "./src/types.ts"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.0.0"
  }
}
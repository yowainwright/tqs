{
  "name": "tqs",
  "version": "0.0.0",
  "description": "quick scripts for typescript",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "tqs": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:quickjs && npm run build:ts",
    "build:quickjs": "bash scripts/build-binary.sh",
    "build:ts": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/cli.js",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepare": "bun run build:ts",
    "release": "release-it"
  },
  "keywords": ["typescript", "cli", "scripts", "tools", "quickjs", "maybefetch"],
  "author": "Jeffry Wainwright",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yowainwright/tqs.git"
  },
  "bugs": {
    "url": "https://github.com/yowainwright/tqs/issues"
  },
  "homepage": "https://github.com/yowainwright/tqs#readme",
  "devDependencies": {
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "oxlint": "^0.9.0",
    "release-it": "^17.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {},
  "peerDependencies": {},
  "files": [
    "dist/",
    "bin/",
    "src/types.ts"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./quickjs": "./dist/quickjs.js",
    "./types": "./src/types.ts"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.0.0"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}",
      "tagAnnotation": "Release v${version}"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "before:init": ["bun run lint", "bun run build:ts", "bun run test"]
    }
  }
}
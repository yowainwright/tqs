import * as std from 'std';

const HTTPBIN_URL = 'http://httpbin/json';
const INVALID_URL = 'http://invalid-domain-that-does-not-exist.internal';

const response = maybefetch(HTTPBIN_URL, 3, 500, 5000, 2.0, 5000);

if (response === null) {
  std.err.puts('FAIL: maybefetch returned null for valid URL\n');
  std.exit(1);
}

let parsed: unknown;
try {
  parsed = JSON.parse(response);
} catch (_) {
  std.err.puts('FAIL: response is not valid JSON\n');
  std.exit(1);
}

if (typeof parsed !== 'object' || parsed === null) {
  std.err.puts('FAIL: parsed response is not an object\n');
  std.exit(1);
}

std.out.puts('PASS: successful fetch returned valid JSON\n');

const failed = maybefetch(INVALID_URL, 1, 100, 500, 1.5, 1000);

if (failed !== null) {
  std.err.puts('FAIL: maybefetch should return null for invalid URL\n');
  std.exit(1);
}

std.out.puts('PASS: failed fetch correctly returned null\n');
std.exit(0);
